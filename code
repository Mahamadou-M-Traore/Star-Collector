<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Star Collector</title>
  <style>
    body {
      margin: 0;
      background: #050510;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      font-family: Arial, sans-serif;
      color: white;
    }
    canvas {
      display: block;
      border: 2px solid #1a1a4a;
      box-shadow: 0 0 40px rgba(0, 150, 255, 0.2);
    }
    #controls {
      margin-top: 10px;
      font-size: 13px;
      color: #556;
      letter-spacing: 1px;
    }
  </style>
</head>
<body>
  <canvas id="gameCanvas" width="600" height="680"></canvas>
  <div id="controls">← → Arrow Keys to move &nbsp;|&nbsp; Collect ⭐ stars &nbsp;|&nbsp; Avoid ☄️ asteroids</div>

  <script>

    // ── SETUP 
    const canvas = document.getElementById("gameCanvas");
    const ctx    = canvas.getContext("2d");


    // ── GAME STATE 
    let score       = 0;
    let level       = 1;
    let gameOver    = false;
    let gameStarted = false;


    // ── PLAYER 
    const player = {
      x:      canvas.width / 2,
      y:      canvas.height - 65,
      width:  44,
      height: 52,
      vx:     0,
      speed:  5,
      tilt:   0
    };


    // ── ARRAYS 
    let stars     = [];
    let asteroids = [];
    let particles = [];


    // ── DIFFICULTY 
    let fallSpeed         = 3;
    let starSpawnRate     = 90;
    let asteroidSpawnRate = 60;
    let starTimer         = 0;
    let asteroidTimer     = 0;


    // ── BACKGROUND STARS 
    const bgStars = [];
    for (let i = 0; i < 100; i++) {
      bgStars.push({
        x:          Math.random() * canvas.width,
        y:          Math.random() * canvas.height,
        radius:     Math.random() * 1.5 + 0.3,
        brightness: Math.random()
      });
    }


    // ── SPAWN FUNCTIONS 
    function spawnStar() {
      stars.push({
        x:        Math.random() * (canvas.width - 40) + 20,
        y:        -20,
        radius:   13,
        speed:    fallSpeed,
        rotation: 0,
        points:   level
      });
    }

    function spawnAsteroid() {
      let size = 18 + Math.random() * 22;
      asteroids.push({
        x:             Math.random() * (canvas.width - size * 2) + size,
        y:             -size,
        radius:        size,
        speed:         fallSpeed * (0.8 + Math.random() * 0.5),
        rotation:      0,
        rotationSpeed: (Math.random() - 0.5) * 0.08,
        sides:         Math.floor(Math.random() * 3) + 5
      });
    }

    function spawnExplosion(x, y) {
      for (let i = 0; i < 24; i++) {
        let angle = (Math.PI * 2 / 24) * i + Math.random() * 0.3;
        particles.push({
          x:      x,
          y:      y,
          vx:     Math.cos(angle) * (2 + Math.random() * 4),
          vy:     Math.sin(angle) * (2 + Math.random() * 4),
          life:   1.0,
          radius: 3 + Math.random() * 3,
          hue:    Math.random() * 60 + 10
        });
      }
    }


    // ── COLLISION DETECTION 
    function circleCollision(a, ra, b, rb) {
      let dx   = a.x - b.x;
      let dy   = a.y - b.y;
      let dist = Math.sqrt(dx * dx + dy * dy);
      return dist < (ra + rb) * 0.8;
    }


    // ── DRAW: BACKGROUND 
    function drawBackground() {
      let grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
      grad.addColorStop(0, "#05050f");
      grad.addColorStop(1, "#100518");
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      for (let s of bgStars) {
        s.brightness += (Math.random() - 0.5) * 0.04;
        s.brightness = Math.max(0.1, Math.min(1.0, s.brightness));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(200,220,255,${s.brightness})`;
        ctx.fill();
      }
    }


    // ── DRAW: PLAYER 
    function drawPlayer() {
      ctx.save();
      ctx.translate(player.x, player.y);
      ctx.rotate(player.tilt);

      ctx.beginPath();
      ctx.moveTo(0, -player.height / 2);
      ctx.lineTo(-player.width / 2, player.height / 2);
      ctx.lineTo( player.width / 2, player.height / 2);
      ctx.closePath();
      ctx.fillStyle   = "#00aaee";
      ctx.fill();
      ctx.strokeStyle = "#88ddff";
      ctx.lineWidth   = 2;
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(-player.width / 2, player.height / 2);
      ctx.lineTo(-8, 0);
      ctx.strokeStyle = "#ffffff44";
      ctx.lineWidth   = 1.5;
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(player.width / 2, player.height / 2);
      ctx.lineTo(8, 0);
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(0, -8, 9, 0, Math.PI * 2);
      ctx.fillStyle   = "#001833";
      ctx.fill();
      ctx.strokeStyle = "#44ccff";
      ctx.lineWidth   = 1.5;
      ctx.stroke();

      let flameH = 14 + Math.random() * 12;
      ctx.beginPath();
      ctx.moveTo(-10, player.height / 2);
      ctx.lineTo(0,   player.height / 2 + flameH);
      ctx.lineTo(10,  player.height / 2);
      ctx.fillStyle = `hsl(${25 + Math.random() * 20}, 100%, 60%)`;
      ctx.fill();

      ctx.restore();
    }


    // ── DRAW: STARS 
    function drawStar(star) {
      ctx.save();
      ctx.translate(star.x, star.y);
      ctx.rotate(star.rotation);

      let glow = ctx.createRadialGradient(0, 0, 2, 0, 0, star.radius * 1.8);
      glow.addColorStop(0, "rgba(255,220,0,0.4)");
      glow.addColorStop(1, "rgba(255,220,0,0)");
      ctx.beginPath();
      ctx.arc(0, 0, star.radius * 1.8, 0, Math.PI * 2);
      ctx.fillStyle = glow;
      ctx.fill();

      ctx.beginPath();
      for (let i = 0; i < 5; i++) {
        let outerAngle = (Math.PI * 2 / 5) * i - Math.PI / 2;
        let innerAngle = outerAngle + Math.PI / 5;
        if (i === 0) ctx.moveTo(Math.cos(outerAngle) * star.radius,
                                Math.sin(outerAngle) * star.radius);
        else         ctx.lineTo(Math.cos(outerAngle) * star.radius,
                                Math.sin(outerAngle) * star.radius);
        ctx.lineTo(Math.cos(innerAngle) * star.radius * 0.42,
                   Math.sin(innerAngle) * star.radius * 0.42);
      }
      ctx.closePath();
      ctx.fillStyle   = "#FFD700";
      ctx.fill();
      ctx.strokeStyle = "#FFA000";
      ctx.lineWidth   = 1.2;
      ctx.stroke();

      ctx.restore();
    }


    // ── DRAW: ASTEROIDS 
    function drawAsteroid(asteroid) {
      ctx.save();
      ctx.translate(asteroid.x, asteroid.y);
      ctx.rotate(asteroid.rotation);

      ctx.beginPath();
      for (let i = 0; i < asteroid.sides; i++) {
        let angle = (Math.PI * 2 / asteroid.sides) * i;
        let r  = asteroid.radius * (0.78 + Math.sin(i * 53) * 0.22);
        let px = Math.cos(angle) * r;
        let py = Math.sin(angle) * r;
        if (i === 0) ctx.moveTo(px, py);
        else         ctx.lineTo(px, py);
      }
      ctx.closePath();
      ctx.fillStyle   = "#7a3c10";
      ctx.fill();
      ctx.strokeStyle = "#c06020";
      ctx.lineWidth   = 2;
      ctx.stroke();

      ctx.strokeStyle = "#3a1a05";
      ctx.lineWidth   = 1;
      ctx.beginPath();
      ctx.moveTo(-asteroid.radius * 0.3, -asteroid.radius * 0.2);
      ctx.lineTo( asteroid.radius * 0.2,  asteroid.radius * 0.3);
      ctx.stroke();

      ctx.restore();
    }


    // ── DRAW: PARTICLES 
    function drawParticles() {
      for (let p of particles) {
        ctx.save();
        ctx.globalAlpha = p.life;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fillStyle = `hsl(${p.hue}, 100%, 60%)`;
        ctx.fill();
        ctx.restore();
      }
    }


    // ── DRAW: HUD 
    function drawHUD() {
      ctx.fillStyle = "rgba(0,0,0,0.5)";
      ctx.fillRect(0, 0, canvas.width, 50);

      ctx.fillStyle = "#FFD700";
      ctx.font      = "bold 20px Arial";
      ctx.textAlign = "left";
      ctx.fillText("⭐ " + score, 15, 33);

      ctx.fillStyle = "#88ccff";
      ctx.textAlign = "right";
      ctx.fillText("LVL " + level, canvas.width - 15, 33);

      let progress = (score % 10) / 10;
      ctx.fillStyle = "#222244";
      ctx.fillRect(canvas.width / 2 - 70, 17, 140, 10);
      let barGrad = ctx.createLinearGradient(canvas.width/2 - 70, 0, canvas.width/2 + 70, 0);
      barGrad.addColorStop(0, "#0099ff");
      barGrad.addColorStop(1, "#00ffcc");
      ctx.fillStyle = barGrad;
      ctx.fillRect(canvas.width / 2 - 70, 17, 140 * progress, 10);
      ctx.strokeStyle = "#445";
      ctx.lineWidth   = 1;
      ctx.strokeRect(canvas.width / 2 - 70, 17, 140, 10);

      ctx.fillStyle = "#667";
      ctx.font      = "10px Arial";
      ctx.textAlign = "center";
      ctx.fillText("NEXT LEVEL", canvas.width / 2, 40);
    }


    // ── UPDATE (GAME LOGIC) 
    function update() {
      player.x += player.vx;

      let targetTilt = (player.vx > 0) ? 0.22 : (player.vx < 0) ? -0.22 : 0;
      player.tilt += (targetTilt - player.tilt) * 0.12;

      let half = player.width / 2;
      if (player.x - half < 0)            player.x = half;
      if (player.x + half > canvas.width) player.x = canvas.width - half;

      starTimer++;
      if (starTimer >= starSpawnRate) { spawnStar(); starTimer = 0; }

      asteroidTimer++;
      if (asteroidTimer >= asteroidSpawnRate) { spawnAsteroid(); asteroidTimer = 0; }

      for (let i = stars.length - 1; i >= 0; i--) {
        let star = stars[i];
        star.y        += star.speed;
        star.rotation += 0.05;

        if (circleCollision(player, 20, star, star.radius)) {
          score += star.points;
          stars.splice(i, 1);
          let newLevel = Math.floor(score / 10) + 1;
          if (newLevel > level) {
            level             = newLevel;
            fallSpeed         = 3 + level * 0.9;
            starSpawnRate     = Math.max(35, 90 - level * 8);
            asteroidSpawnRate = Math.max(22, 60 - level * 5);
          }
          continue;
        }
        if (star.y > canvas.height + 20) stars.splice(i, 1);
      }

      for (let i = asteroids.length - 1; i >= 0; i--) {
        let asteroid = asteroids[i];
        asteroid.y        += asteroid.speed;
        asteroid.rotation += asteroid.rotationSpeed;

        if (circleCollision(player, 19, asteroid, asteroid.radius)) {
          spawnExplosion(player.x, player.y);
          gameOver = true;
        }
        if (asteroid.y > canvas.height + asteroid.radius) asteroids.splice(i, 1);
      }

      for (let i = particles.length - 1; i >= 0; i--) {
        let p = particles[i];
        p.x    += p.vx;
        p.y    += p.vy;
        p.vy   += 0.1;
        p.life -= 0.025;
        if (p.life <= 0) particles.splice(i, 1);
      }
    }


    // ── DRAW (RENDERING) 
    function draw() {
      drawBackground();
      drawParticles();
      if (!gameOver) drawPlayer();
      for (let star     of stars)     drawStar(star);
      for (let asteroid of asteroids) drawAsteroid(asteroid);
      drawHUD();

      if (gameOver) {
        ctx.fillStyle = "rgba(0,0,0,0.65)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.textAlign = "center";
        ctx.fillStyle = "#ff4455";
        ctx.font      = "bold 54px Arial";
        ctx.fillText("GAME OVER", canvas.width / 2, canvas.height / 2 - 70);
        ctx.fillStyle = "white";
        ctx.font      = "24px Arial";
        ctx.fillText("Score: " + score + "   |   Level: " + level,
                     canvas.width / 2, canvas.height / 2 - 20);
        drawButton(canvas.width / 2, canvas.height / 2 + 55, "▶  Play Again");
      }

      if (!gameStarted && !gameOver) {
        ctx.fillStyle = "rgba(0,0,0,0.55)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.textAlign = "center";
        ctx.fillStyle = "#00ccff";
        ctx.font      = "bold 46px Arial";
        ctx.fillText("STAR COLLECTOR", canvas.width / 2, canvas.height / 2 - 100);
        ctx.fillStyle = "white";
        ctx.font      = "18px Arial";
        ctx.fillText("Collect ⭐  stars — avoid ☄️  asteroids",
                     canvas.width / 2, canvas.height / 2 - 48);
        ctx.fillText("Use ← → Arrow Keys to move",
                     canvas.width / 2, canvas.height / 2 - 16);
        ctx.fillStyle = "#FFD700";
        ctx.font      = "16px Arial";
        ctx.fillText("Every 10 stars = Level Up!  Speed increases each level.",
                     canvas.width / 2, canvas.height / 2 + 20);
        drawButton(canvas.width / 2, canvas.height / 2 + 85, "▶  Start Game");
      }
    }

    function drawButton(cx, cy, label) {
      let bw = 190, bh = 48;
      ctx.fillStyle = "#0099cc";
      ctx.beginPath();
      ctx.roundRect(cx - bw/2, cy - bh/2, bw, bh, 10);
      ctx.fill();
      ctx.fillStyle = "#e0f8ff";
      ctx.font      = "bold 21px Arial";
      ctx.textAlign = "center";
      ctx.fillText(label, cx, cy + 7);
    }


    // ── GAME LOOP 
    function gameLoop() {
      if (gameStarted && !gameOver) update();
      draw();
      requestAnimationFrame(gameLoop);
    }


    // ── RESTART 
    function restartGame() {
      score             = 0;
      level             = 1;
      fallSpeed         = 3;
      starSpawnRate     = 90;
      asteroidSpawnRate = 60;
      starTimer         = 0;
      asteroidTimer     = 0;
      stars             = [];
      asteroids         = [];
      particles         = [];
      player.x          = canvas.width / 2;
      player.vx         = 0;
      player.tilt       = 0;
      gameOver          = false;
      gameStarted       = true;
    }


    // ── INPUT 
    document.addEventListener("keydown", function(e) {
      if (e.key === "ArrowRight") player.vx =  player.speed;
      if (e.key === "ArrowLeft")  player.vx = -player.speed;
      if (!gameStarted && !gameOver) gameStarted = true;
    });

    document.addEventListener("keyup", function(e) {
      if (e.key === "ArrowRight" || e.key === "ArrowLeft") player.vx = 0;
    });

    canvas.addEventListener("click", function(e) {
      let rect = canvas.getBoundingClientRect();
      let mx = (e.clientX - rect.left)  * (canvas.width  / rect.width);
      let my = (e.clientY - rect.top)   * (canvas.height / rect.height);
      let bw = 190, bh = 48;
      if (gameOver) {
        let cx = canvas.width / 2, cy = canvas.height / 2 + 55;
        if (mx > cx-bw/2 && mx < cx+bw/2 && my > cy-bh/2 && my < cy+bh/2) restartGame();
      }
      if (!gameStarted && !gameOver) {
        let cx = canvas.width / 2, cy = canvas.height / 2 + 85;
        if (mx > cx-bw/2 && mx < cx+bw/2 && my > cy-bh/2 && my < cy+bh/2) gameStarted = true;
      }
    });


    // ── START 
    gameLoop();

  </script>
</body>
</html>
